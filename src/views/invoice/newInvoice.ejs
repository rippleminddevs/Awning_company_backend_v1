<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customer Quote - The Awning Company</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: "Helvetica Neue", Arial, sans-serif;
    font-size: 12px;
    color: #222;
    background: #fff;
    padding: 10px;
  }

  .divider { border:none; border-top:1px solid #ddd; margin:14px 0; }

  /* ── Company header ── */
  .header {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    align-items: start;
    margin-bottom: 16px;
  }
  .company-logo { width: 200px; height: auto; object-fit: contain; }
  .info-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 12px;
    font-size: 11px;
    line-height: 1.75;
    align-content: start;
  }
  .info-grid .lbl { color: #888; white-space: nowrap; }
  .info-grid .val { font-weight: 600; }

  /* ── Quote meta bar ── */
  .meta-bar {
    display: flex;
    gap: 32px;
    align-items: center;
    background: #2d8659;
    color: #fff;
    padding: 9px 18px;
    border-radius: 4px;
    margin-bottom: 14px;
  }
  .meta-item p:first-child { font-size: 9px; text-transform:uppercase; letter-spacing:.07em; opacity:.7; }
  .meta-item p:last-child  { font-size: 15px; font-weight: 700; margin-top:1px; }

  /* ── Address blocks ── */
  .addresses {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 12px;
  }
  .addr-block { border:1px solid #e0e0e0; border-radius:4px; padding:10px 12px; font-size:11px; line-height:1.65; }
  .addr-title { font-size:9px; text-transform:uppercase; letter-spacing:.07em; color:#2d8659; font-weight:700; margin-bottom:5px; }
  .addr-name  { font-weight:700; font-size:12px; margin-bottom:2px; }

  .addr-footer { display:grid; grid-template-columns:1fr 1fr; gap:4px; font-size:11px; margin-bottom:14px; }
  .addr-footer span  { color:#666; }
  .addr-footer strong { color:#222; }

  /* ── Section header ── */
  .section-header {
    background:#333; color:#fff; font-size:10px; font-weight:700;
    text-transform:uppercase; letter-spacing:.08em;
    padding:5px 10px; border-radius:3px; margin-bottom:8px;
  }

  /* ── Product card ── */
  .product-card {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    overflow: hidden;
    margin-bottom: 14px;
  }
  .product-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f5f5f5;
    border-bottom: 1px solid #e0e0e0;
    padding: 7px 12px;
  }
  .product-card-header .item-num {
    width: 22px; height: 22px; border-radius: 50%;
    background: #2d8659; color: #fff;
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin-right: 8px; flex-shrink: 0;
  }
  .product-card-header .item-name { font-size: 13px; font-weight: 700; color: #222; }
  .product-card-header .item-price { font-size: 13px; font-weight: 700; color: #2d8659; }

  .product-card-body { display: flex; gap: 0; }

  /* photo col */
  .photo-col {
    width: 100px; flex-shrink: 0;
    display: flex; align-items: flex-start; justify-content: center;
    /* padding: 12px 8px; */
    /* border-right: 1px solid #eee; */
    background: #fafafa;
  }
  .fields-photo-col{
    display: flex; align-items: center; margin-bottom: 12px;
  }
  .photo-col img { width: 100px; height: auto; object-fit: contain; border-radius: 5px; }
  .photo-col .no-photo {
    width: 72px; height: 60px; background: #efefef;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; color: #aaa; border-radius: 3px; text-align: center;
  }

  /* fields + options col */
  .details-col { flex: 1; padding: 10px 14px; }

  /* dynamic fields grid */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 6px 14px;
    margin-left: 10px;
    width: 100%;
  }
  .field-lbl { font-size: 9px; text-transform: uppercase; letter-spacing: .06em; color: #999; margin-bottom: 1px; }
  .field-val { font-size: 11px; font-weight: 600; color: #222; }

  /* fabric section */
  .fabric-section { gap: 10px; margin-top: 8px; margin-bottom: 4px; padding: 6px 10px; background: #f7f9f7; border: 1px solid #d4e8da; border-radius: 5px; }
  .fabric-detail {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 5px;
  }
  .fabric-detail .fabric-icon img { width: 100px; height: auto; object-fit: contain; }
  .fabric-info { display: flex; flex-direction: column; gap: 1px; }
  .fabric-lbl { font-size: 12px; text-transform: uppercase; letter-spacing: .07em; color: #2d8659; font-weight: 700; }
  .fabric-num { font-size: 12px; font-weight: 700; color: #222; }
  .fabric-color { font-size: 10px; color: #555; }

  /* options table */
  .options-section { margin-top: 8px; }
  .options-title { font-size: 9px; text-transform: uppercase; letter-spacing: .06em; color: #2d8659; font-weight: 700; margin-bottom: 4px; }
  .options-table { width: 100%; border-collapse: collapse; font-size: 10px; }
  .options-table th { background: #f0f0f0; padding: 3px 8px; text-align: left; font-weight: 600; color: #555; border: 1px solid #e8e8e8; }
  .options-table td { padding: 3px 8px; border: 1px solid #ebebeb; vertical-align: top; }
  .options-table tr:nth-child(even) td { background: #fafafa; }
  .opt-price { color: #2d8659; font-weight: 600; text-align: right; }

  /* pricing footer of each item */
  .item-pricing {
    display: flex;
    justify-content: flex-end;
    gap: 24px;
    padding: 8px 14px;
    border-top: 1px solid #eee;
    background: #fafafa;
    font-size: 11px;
  }
  .price-lbl { color: #888; margin-right: 4px; }
  .price-val { font-weight: 700; }
  .price-val.green { color: #2d8659; font-size: 13px; }

  /* note row */
  .note-card {
    border: 1px solid #fbbf24;
    border-left: 4px solid #d97706;
    border-radius: 4px;
    background: #fffbeb;
    padding: 10px 14px;
    margin-bottom: 14px;
  }
  .note-card h4 { font-size: 11px; color: #b45309; margin-bottom: 5px; }
  .note-card p  { font-size: 11px; white-space: pre-wrap; color: #555; }

  /* ── Summary + payment ── */
  .bottom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 18px; }
  .summary-table { width: 100%; border-collapse: collapse; font-size: 11px; }
  .summary-table td { padding: 5px 8px; border-bottom: 1px solid #eee; }
  .summary-table .r { text-align: right; }
  .summary-table .total-row td { border-top: 2px solid #2d8659; border-bottom: none; font-weight: 700; font-size: 13px; color: #2d8659; padding-top: 8px; }

  /* ── Terms ── */
  .terms { font-size: 10px; color: #444; line-height: 1.55; margin-bottom: 18px; }
  .terms h4 { font-size: 11px; color: #2d8659; margin-bottom: 6px; }
  .terms ol { margin-left: 16px; }
  .terms li { margin-bottom: 3px; }

  /* ── Signature ── */
  .sig-section { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 20px; }
  .sig-field label { font-size: 12px; color: #666; }
  .sig-line {
    border-bottom: 1.5px solid #333;
    margin-top: 35px;
    height: 50px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 10px;
  }
  .sig-line img {
    width: 100%;
    object-fit: contain;
    max-height: 100%;
  }
  /* ── Sponsors ── */
  .sponsors { display:flex; flex-wrap:wrap; justify-content:center; gap:16px; padding-top:14px; border-top:1px solid #e0e0e0; }
  .sponsors img { max-height:36px; width:auto; opacity:.75; }

  /* ── Office section ── */
  .office-section { page-break-before: always; padding-top: 20px; }
  .office-header  { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .office-title   { background:#333; color:#fff; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; padding:6px 14px; border-radius:3px; }
  .office-sub     { font-size:10px; color:#999; font-style:italic; }
  .office-grid    { display:grid; grid-template-columns:1fr 1fr; gap:0 40px; }
  .office-row     { display:flex; align-items:flex-end; gap:12px; padding:7px 0; border-bottom:1px solid #e0e0e0; font-size:11px; }
  .o-label        { width:230px; flex-shrink:0; color:#555; }
  .o-value        { font-weight:600; color:#222; }
  .o-blank        { flex:1; border-bottom:1px dotted #aaa; height:14px; }
</style>
</head>
<body>

<!-- ═══ COMPANY HEADER ═══════════════════════════════════ -->
<div class="header">
  <div>
    <img src="<%= config.app.url %>/static/uploads/companylogo.png" class="company-logo" alt="Logo">
  </div>

  <div class="info-grid">
    <span class="lbl">Rep Name</span>  <span class="val"><%= salesperson.name || '—' %></span>
    <span class="lbl">Rep Cell</span>  <span class="val"><%= salesperson.cell || '—' %></span>
    <span class="lbl">Rep Email</span> <span class="val"><%= salesperson.email || '—' %></span>
  </div>

  <div class="info-grid">
    <span class="lbl">Office #</span>  <span class="val"><%= company.office %></span>
    <span class="lbl">Address</span>   <span class="val"><%= company.address %></span>
    <span class="lbl">Website</span>   <span class="val"><%= company.website %></span>
    <span class="lbl">Lic #</span>     <span class="val"><%= company.license %></span>
  </div>
</div>

<hr class="divider">

<!-- ═══ QUOTE META ════════════════════════════════════════ -->
<div class="meta-bar">
  <div class="meta-item">
    <p>Quote #</p>
    <p><%= salesperson.quoteNumber %></p>
  </div>
  <div class="meta-item">
    <p>Quote Created</p>
    <p><%= salesperson.quoteCreated %></p>
  </div>
  <div class="meta-item">
    <p>Quote Expires</p>
    <p><%= salesperson.quoteExpiry %></p>
  </div>
</div>

<!-- ═══ CUSTOMER / PROJECT / BILL TO ═════════════════════ -->
<div class="addresses">
  <div class="addr-block">
    <div class="addr-title">Customer Details</div>
    <div class="addr-name"><%= customer.name   || '—' %></div>
    <div><%= customer.street  || '—' %></div>
    <div><%= customer.cityZip || '—' %></div>
  </div>
  <div class="addr-block">
    <div class="addr-title">Project Address</div>
    <div class="addr-name"><%= project.name   || '—' %></div>
    <div><%= project.street  || '—' %></div>
    <div><%= project.cityZip || '—' %></div>
  </div>
  <div class="addr-block">
    <div class="addr-title">Bill To</div>
    <div class="addr-name"><%= billTo.name   || '—' %></div>
    <div><%= billTo.street  || '—' %></div>
    <div><%= billTo.cityZip || '—' %></div>
  </div>
</div>

<div class="addr-footer">
  <div><span>Source: </span><strong><%= customer.source   || '—' %></strong></div>
  <div style="text-align: end;"><span>Approx. Lead Time: </span><strong><%= customer.leadTime || '—' %></strong></div>
</div>

<!-- ═══ PRODUCT LINE ITEMS ═══════════════════════════════ -->
<div class="section-header">Product Details</div>

<% items.forEach(function(item, idx) { %>
  <% if (item.isNote) { %>
    <div class="note-card">
      <h4>Special Instructions</h4>
      <p><%= item.noteText %></p>
    </div>
  <% } else { %>
    <div class="product-card">

      <!-- Card header: item # · name · sub-total -->
      <div class="product-card-header">
        <div style="display:flex;align-items:center;gap:6px;">
          <div class="item-num"><%= idx + 1 %></div>
          <span class="item-name"><%= item.title || '—' %></span>
          <% if (item.qty && item.qty > 1) { %><span style="font-size:11px;color:#666;font-weight:400;">× <%= item.qty %></span><% } %>
        </div>
        <span class="item-price"><%= item.subTotal %></span>
      </div>

      <!-- Card body: photo + details -->
      <div class="product-card-body">


        <!-- Dynamic fields + options -->
        <div class="details-col">
          <div class="fields-photo-col">
            <!-- Photo -->
            <div class="photo-col">
              <% if (item.image) { %>
                <img src="<%= item.image %>" alt="<%= item.title %>">
              <% } else { %>
                <div class="no-photo">No Photo</div>
              <% } %>
            </div>

            <!-- Dynamic field grid — all fields except location / install / story -->
            <%
              var META_KEYS = ['location', 'install', 'story'];
              var META_LABELS = { location: 'Location', install: 'Install', story: 'Story' };
              var regularFields = (item.fields || []).filter(function(f) { return !META_KEYS.includes(f.key); });
              var metaFields = META_KEYS.map(function(k) {
                var found = (item.fields || []).find(function(f) { return f.key === k; });
                return found || { key: k, label: META_LABELS[k], value: '-' };
              });
            %>
            <div style="flex:1; display:flex; flex-direction:column; gap:8px;">
              <% if (regularFields.length > 0) { %>
                <div class="fields-grid">
                  <% regularFields.forEach(function(f) { %>
                    <div class="field-item">
                      <div class="field-lbl"><%= f.label %></div>
                      <div class="field-val"><%= f.value %></div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
              <% if (metaFields.length > 0) { %>
              <div class="fields-grid">
                <% metaFields.forEach(function(f) { %>
                  <div class="field-item">
                    <div class="field-lbl"><%= f.label %></div>
                    <div class="field-val"><%= f.value && f.value.toString().trim() !== '' ? f.value : '-' %></div>
                  </div>
                <% }) %>
              </div>
              <% } %>
            </div>
          </div>

         
          <!-- Fabric -->
          <% if (item.fabric && item.fabric.number) { %>
            <div class="fabric-section">
              <div class="fabric-lbl-col">
                <span class="fabric-lbl">Fabric</span>
              </div>
              <div class="fabric-detail">
                <% if (item.fabric.type == 'sunbrella') { %>
                <div class="fabric-icon">
                  <img src="<%= item.sunbrellaLogo %>" alt="Sunbrella Logo">
                </div>
                <% } %>
                <div class="fabric-info">
                  <!-- <span class="fabric-lbl">Fabric</span> -->
                  <span class="fabric-num">#<%= item.fabric.number %></span>
                  <% if (item.fabric.name) { %>
                    <span class="fabric-color"><%= item.fabric.name %></span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>

          <!-- Options -->
          <% if (item.options && item.options.length > 0) { %>
            <div class="options-section">
              <div class="options-title">Add-on Options</div>
              <table class="options-table">
                <thead>
                  <tr>
                    <th>Option</th>
                    <th>Detail</th>
                    <th style="text-align:center;">Yes/No</th>
                    <th>Qty</th>
                    <th style="text-align:right;">Price</th>
                  </tr>
                </thead>
                <tbody>
                  <% item.options.forEach(function(opt) { %>
                    <tr>
                      <td>
                        <strong><%= opt.label %></strong><% if (opt.parentLabel) { %> <span style="color:#000;font-weight:400;">(<%= opt.parentLabel %>)</span><% } %>
                      </td>
                      <td><%= opt.detail || '—' %></td>
                      <td style="text-align:center; font-weight:600; color:<%= opt.yn === 'No' ? '#c0392b' : '#2d8659' %>;"><%= opt.yn || 'Yes' %></td>
                      <td><%= opt.qty    || '—' %></td>
                      <td class="opt-price"><%= opt.price || '$0.00' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

        </div><!-- /details-col -->
      </div><!-- /card-body -->

      <!-- Pricing footer -->
      <div class="item-pricing">
        <div>
          <span class="price-lbl">Unit Price</span>
          <span class="price-val"><%= item.unitPrice %></span>
        </div>
        <% if (item.optionsTotal) { %>
        <div>
          <span class="price-lbl">Add-ons</span>
          <span class="price-val"><%= item.optionsTotal %></span>
        </div>
        <% } %>
        <% if (item.installPrice) { %>
        <div>
          <span class="price-lbl">Install</span>
          <span class="price-val"><%= item.installPrice %></span>
        </div>
        <% } %>
        <% if (item.qty && item.qty > 1) { %>
        <div>
          <span class="price-lbl">× <%= item.qty %> units</span>
        </div>
        <% } %>
        <div>
          <span class="price-lbl">Sub Total</span>
          <span class="price-val green"><%= item.subTotal %></span>
        </div>
      </div>

    </div><!-- /product-card -->
  <% } %>
<% }) %>

<!-- ═══ TOTALS + PAYMENT ══════════════════════════════════ -->
<div class="bottom-grid">
  <div>
    <div class="section-header">Totals</div>
    <table class="summary-table">
      <tr><td>Sub Total</td><td class="r"><%= summary.subtotal  %></td></tr>
      <tr style="color: #c0392b;"><td>Discount $</td>       <td class="r"><%= summary.discount  %></td></tr>
      <tr><td>Additional Install Charge ( $ )</td><td class="r">+<%= summary.additionalInstallationCharges %></td></tr>
      <tr class="total-row"><td>Grand Total</td><td class="r"><%= summary.grandTotal %></td></tr>
    </table>
  </div>
  <div>
    <div class="section-header">Payment Schedule</div>
    <table class="summary-table">
      <tr><td>Number of Installments</td>          <td class="r"><%= payment.numberOfInstallments %></td></tr>
      <tr style="color: #c0392b;"><td>Down Payment</td>                    <td class="r"><%= payment.downPayment %></td></tr>
      <tr class="total-row"><td>Balance Due Upon Installation</td><td class="r"><%= payment.balanceDue %></td></tr>
      <tr><td>Payment Method</td>                  <td class="r"><%= payment.paymentMethod %></td></tr>
    </table>
  </div>
</div>

<!-- ═══ TERMS + SIGNATURE ════════════════════════════════ -->
<div class="terms">
  <h4>Terms and Conditions</h4>
  <ol>
    <% terms.forEach(function(term) { %><li><%= term %></li><% }) %>
  </ol>
</div>

<div class="sig-section">
  <div class="sig-field"><label>Acceptance Signature:</label>
    <div class="sig-line">
      <% if (signatureData?.sign) { %>
        <img src="<%= signatureData?.sign %>" alt="Signature">
      <% } %>
    </div>
  </div>
  <div class="sig-field"><label>Date:</label>
    <div class="sig-line">
      <% if (signatureData?.date) { %>
        <%= signatureData?.date %>
      <% } %>
    </div>
  </div>
</div>

<% if (company.sponsers && company.sponsers.length > 0) { %>
<div class="sponsors">
  <% company.sponsers.forEach(function(s) { %><img src="<%= s %>" alt="sponsor"><% }) %>
</div>
<% } %>

<!-- ═══ OFFICE USE ONLY (page break) ═════════════════════ -->
<div class="office-section">
  <div class="office-header">
    <span class="office-title">Office Use Only</span>
    <span class="office-sub">— Internal office use — prints as last sheet</span>
  </div>
  <div class="office-grid">
    <div>
      <div class="office-row"><span class="o-label">Customer Name</span>                    <span class="o-value"><%= officeOnly.customerName %></span></div>
      <div class="office-row"><span class="o-label">Sales Person</span>                     <span class="o-value"><%= officeOnly.salesPerson %></span></div>
      <div class="office-row"><span class="o-label">Sale Date</span>                        <span class="o-value"><%= officeOnly.saleDate %></span></div>
      <div class="office-row"><span class="o-label">Date Order Handed Into the Office</span><span class="o-blank"></span></div>
      <div class="office-row"><span class="o-label">Deposit Received</span>                 <span class="o-value"><%= officeOnly.depositReceived %></span></div>
      <div class="office-row"><span class="o-label">Deposit Source</span>                   <span class="o-value"><%= officeOnly.depositSource %></span></div>
    </div>
    <div>
      <div class="office-row"><span class="o-label">Date Order Processed by Office</span>   <span class="o-blank"></span></div>
      <div class="office-row"><span class="o-label">Date New Business Set Up Complete</span><span class="o-blank"></span></div>
      <div class="office-row"><span class="o-label">Date Received by Production</span>      <span class="o-blank"></span></div>
      <div class="office-row"><span class="o-label">Lead Time</span>                        <span class="o-value"><%= officeOnly.leadTime %></span></div>
      <% if (officeOnly.hiddenMarkup !== '—') { %>
      <div class="office-row"><span class="o-label">Hidden Markup</span>                    <span class="o-value"><%= officeOnly.hiddenMarkup %></span></div>
      <% } %>
    </div>
  </div>
</div>

</body>
</html>
